{
  "name": "stardew-vision ROCm PyTorch ML Development",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "stpousty-devcontainer",
      "uid": "2112",
      "gid": "2112",
      "upgradePackages": false
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
  },

  "runArgs": [
    "--device=/dev/kfd",
    "--device=/dev/dri",
    "--group-add=video",
    "--group-add=105",
    "--ipc=host",
    "--shm-size=8G",
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined",
    "--memory=20g",
    "--cpus=8",
    "--ulimit=memlock=-1",
    "--ulimit=stack=67108864",
    "--mount", "type=bind,source=${env:SSH_AUTH_SOCK},target=/tmp/ssh-agent.sock",
    "--mount", "type=bind,source=${localEnv:HOME}/.config/gcloud,target=/home/stpousty-devcontainer/.config/gcloud,readonly",
    "--mount", "type=bind,source=${localEnv:HOME}/data,target=/data",
    // Wayland socket forwarding — mount host socket into container.
    // Host socket lives at $XDG_RUNTIME_DIR/$WAYLAND_DISPLAY (e.g. /run/user/1000/wayland-0).
    // We mount it to /tmp/$WAYLAND_DISPLAY so it's accessible regardless of XDG_RUNTIME_DIR permissions.
    "--volume=/run/user/1000/wayland-0:/tmp/wayland-0"
  ],

  "containerEnv": {
    // Wayland display forwarding
    "WAYLAND_DISPLAY": "wayland-0",
    "XDG_RUNTIME_DIR": "/tmp",
    // Tell Qt/GTK to use Wayland backend for cv2.imshow and other GUI apps
    "QT_QPA_PLATFORM": "wayland",
    "GDK_BACKEND": "wayland",
    "HIP_VISIBLE_DEVICES": "0",
    "ROCM_HOME": "/opt/rocm",
    "ROCBLAS_USE_HIPBLASLT": "1",
    "PYTHONPATH": "/workspaces/stardew-vision/src",
    "HF_HOME": "/workspaces/stardew-vision/.cache/huggingface",
    "TORCH_HOME": "/workspaces/stardew-vision/.cache/torch",
    "TRANSFORMERS_CACHE": "/workspaces/stardew-vision/.cache/huggingface/transformers",
    "SSH_AUTH_SOCK": "/tmp/ssh-agent.sock",
    "VIRTUAL_ENV": "${containerWorkspaceFolder}/.venv",
    "ANTHROPIC_VERTEX_PROJECT_ID": "${localEnv:ANTHROPIC_VERTEX_PROJECT_ID}",
    "ANTHROPIC_VERTEX_REGION": "${localEnv:ANTHROPIC_VERTEX_REGION}",
    "CLAUDE_CODE_USE_VERTEX": "${localEnv:CLAUDE_CODE_USE_VERTEX}"
  },

  // No volume mounts needed - VSCode bind-mounts the entire workspace folder by default.
  // models/, datasets/, .cache/ are regular project directories visible from both host and container.

  "workspaceFolder": "/workspaces/stardew-vision",
  "remoteUser": "stpousty-devcontainer",

  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "files.watcherExclude": {
          "**/.cache/**": true,
          "**/models/**": true,
          "**/datasets/**": true
        },
        "terminal.integrated.defaultProfile.linux": "bash",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
          }
        },
        "ruff.enable": true,
        "ruff.organizeImports": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "github.copilot",
        "ms-toolsai.jupyter"
      ]
    },
    "jetbrains": {
      "backend": "IU",
      "plugins": [
        "PythonCore",
        "net.ashald.envfile",
        "ru.adelf.idea.dotenv",
        "net.seesharpsoft.intellij.plugins.csv",
        "nl.bryanderidder.regexrenamefiles",
        "com.intellij.plugins.watcher",
        "intellij.python.lsp"
      ]
    }
  },

  "forwardPorts": [6006, 8888],

  "postCreateCommand": ".devcontainer/setup-environment.sh",

  "postStartCommand": "cat /workspaces/${localWorkspaceFolderBasename}/GETTING_STARTED.md 2>/dev/null || true",

  "hostRequirements": {
    "gpu": "optional",
    "memory": "24gb"
  }
}